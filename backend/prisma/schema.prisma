generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  mentor
  etudiant
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mentorConversations   Conversation[] @relation("MentorConversations")
  etudiantConversations Conversation[] @relation("EtudiantConversations")

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Conversation {
  id         String   @id @default(uuid())
  mentorId   String
  etudiantId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mentor   User @relation("MentorConversations", fields: [mentorId], references: [id])
  etudiant User @relation("EtudiantConversations", fields: [etudiantId], references: [id])

  messages Message[]

  @@unique([mentorId, etudiantId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  fromUserId     String
  toUserId       String
  text           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  fromUser User @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser   User @relation("ReceivedMessages", fields: [toUserId], references: [id])

  @@index([conversationId, createdAt])
}
